rules_version = '2';

// Khair Murafiq Empire OS - Security Rules Final Draft
// Owner Email: khairul2052007@gmail.com
// 
// IMPORTANT SECURITY NOTES:
// 1. These rules enforce strict Owner-Only access to all control room collections.
// 2. Any user attempting to read or write to the database who is not authenticated,
//    or whose email is not exactly khairul2052007@gmail.com, will be explicitly DENIED.

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to cryptographically verify the Owner
    function isOwner() {
      return request.auth != null && request.auth.token.email == 'khairul2052007@gmail.com';
    }

    // Projects Collection
    match /control_projects/{docId} {
      allow read, write: if isOwner();
    }

    // Tasks Collection
    match /control_tasks/{docId} {
      allow read, write: if isOwner();
    }

    // Alerts Collection
    match /control_alerts/{docId} {
      allow read, write: if isOwner();
    }

    // Settings Collection
    match /control_settings/{docId} {
      allow read, write: if isOwner();
    }

    // Activity Logs Collection
    match /control_activity_logs/{docId} {
      allow read, write: if isOwner();
    }

    // Reports Collection
    match /control_reports/{docId} {
      allow read, write: if isOwner();
    }

    // Connection Tests Collection
    match /control_connection_tests/{docId} {
      allow read, write: if isOwner();
    }
    // Website Agent Collections
    match /control_website_events/{docId} {
      allow read, write: if isOwner();
    }

    match /control_website_errors/{docId} {
      allow read, write: if isOwner();
    }

    match /control_website_health/{docId} {
      allow read, write: if isOwner();
    }
    
    // Default Deny Rule (Fallback)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
